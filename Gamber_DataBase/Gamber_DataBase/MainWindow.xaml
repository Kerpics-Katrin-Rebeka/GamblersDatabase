<Window x:Class="Gamber_DataBase.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gamber_DataBase"
        mc:Ignorable="d"
        Title="MainWindow" Height="750" Width="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="0.75*"></RowDefinition>
            <RowDefinition Height="1.5*"></RowDefinition>
            <RowDefinition Height="100"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <Label HorizontalAlignment="Center" Margin="10,10,10,10" FontSize="30" FontWeight="Bold">Gambler Database</Label>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Vertical">
            <Label HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Margin="10">Keresés</Label>
            <TextBox x:Name="TB_search" Width="400" Height="50" Margin="10"/>
        </StackPanel>
        <DataGrid Grid.Row="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Név" Width="1.5*"></DataGridTextColumn>
                <DataGridTextColumn Header="Credit"  Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Kártyaszám"  Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Lakcím"  Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Adósság"  Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Születési Dátum"  Width="*"></DataGridTextColumn>
                <DataGridTextColumn Width="Auto" Header="18+"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Grid.ColumnSpan="2">
            <Button x:Name="BTN_new" Width="250" Height="50" Margin="10" FontWeight="Bold" FontSize="15">Új data felvétele</Button>
            <Button x:Name="BTN_delete" Width="250" Height="50" Grid.Column="1" Margin="10" FontWeight="Bold" FontSize="15">Data törlése</Button>
        </StackPanel>
    </Grid>
</Window>
