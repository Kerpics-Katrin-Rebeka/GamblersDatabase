<Window x:Class="Gamber_DataBase.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gamber_DataBase"
        mc:Ignorable="d"
        Title="MainWindow" Height="750" Width="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="0.75*"></RowDefinition>
            <RowDefinition Height="1.5*"></RowDefinition>
            <RowDefinition Height="100"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <Label HorizontalAlignment="Center" Margin="10,10,10,10" FontSize="30" FontWeight="Bold">Gambler Database</Label>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Vertical">
            <Label HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Margin="10">Keresés</Label>
            <TextBox x:Name="TB_search" Width="400" Height="50" Margin="10" TextChanged="TB_search_TextChanged"/>
        </StackPanel>
        <DataGrid x:Name="GamblersDataGrid" Grid.Row="2" AutoGenerateColumns="False" ItemsSource="{Binding GamblersList}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Név" Width="1.5*" Binding="{Binding Name}"></DataGridTextColumn>
                <DataGridTextColumn Header="Credit"  Width="*" Binding="{Binding CreditScore}"></DataGridTextColumn>
                <DataGridTextColumn Header="Kártyaszám"  Width="*" Binding="{Binding CardInfo}"></DataGridTextColumn>
                <DataGridTextColumn Header="Lakcím"  Width="*" Binding="{Binding Address}"></DataGridTextColumn>
                <DataGridTextColumn Header="Adósság"  Width="*" Binding="{Binding Debt}"></DataGridTextColumn>
                <DataGridTextColumn Header="Születési Dátum"  Width="*" Binding="{Binding Birthday}"></DataGridTextColumn>
                <DataGridCheckBoxColumn Header="18+" Width="Auto" Binding="{Binding isMinor}" />
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Grid.ColumnSpan="2">
            <Button x:Name="BTN_new" Width="250" Height="50" Margin="10" FontWeight="Bold" FontSize="15" Click="BTN_new_Click">Új data felvétele</Button>
            <Button x:Name="BTN_delete" Width="250" Height="50" Grid.Column="1" Margin="10" FontWeight="Bold" FontSize="15" Click="BTN_delete_Click">Data törlése</Button>
        </StackPanel>
    </Grid>
</Window>
